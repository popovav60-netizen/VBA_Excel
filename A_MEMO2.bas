#If Win64 Then  ' 64 битный Windows
    #If VBA7 Then  ' Office 2010 и выше (64 битный Office)
                ' GetTickCount - возвращает кол-во миллисекунд (счетчик) прошедшее с момента запуска системы (загрузка ядра ОС)
                '---------v                 нет входящих параметров -----v
        Private Declare PtrSafe Function GetTickCount Lib "kernel32.dll" () As Long
        '------------------^
                ' здесь можно дать описание других процедур и функций
                ' ...
                
    #Else ' 32 битный Office
        Private Declare Function GetTickCount Lib "kernel32.dll" () As Long
                
                ' здесь можно дать описание других процедур и функций
                ' ...
                
    #End If
#Else   ' 32 битный Windows (однозначно что Office 32 битный) + для примера Alias
    Private Declare Function GetTickCount Lib "kernel32.dll" Alias "GetTickCount32" () As Long
        
        ' здесь можно дать описание других процедур и функций
        ' ...
        
#End If
' GetTickCount часто используется для определения времени выполнения блока команд:
'   1. получаем значение до начала каких-то действий (lStart& = GetTickCount())
'   2. что-то делаем...
'   3. получаем значение после (lStop& = GetTickCount())
'   4. вычисляем разницу между после и до в миллисекундах (lDelta& = lStop& - lStart&)
'   и приводим к виду времени, если надо... mclsComFn.FormatTickToTime(lDelta&)...

' ВНИМАНИЕ!!! если компьютер не выключался чуть более 49 дней - происходит сброс счетчика.
' Вопрос: почему?
