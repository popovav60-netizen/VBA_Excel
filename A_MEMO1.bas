'---------------------------
' СОЗДАВАЕМЫЕ ПОЛЬЗОВАТЕЛЕМ ТИПЫ ДАННЫХ
'---------------------------
' Enum          - перечисления
'    Public Enum eSPF
'        spfAllUsersDesktop = 1 'индекс начала отсчета
'        spfAllUsersStartMenu   'это будет 2
'        spfAllUsersPrograms    'это будет 3
'    End Enum
'    Dim eWhat As eSPF
'    ...
'       If eWhat = spfAllUsersPrograms Then
'
' Type          - создание собственных наборов (структуры данных)
'    Public Type INT64
'        LoPart As Long
'        HiPart As Long
'    End Type
'    Dim tInt64 As INT64
'       tInt64.LoPart = 2147483647
'       tInt64.HiPart = 467382
'
' CLASS         - позволяет реализовать пользовательские объекты, с заданными методами, свойствами, событиями
'   и сохранять свое состояние (настройки) на всем протяжении жизни класса (объекта)
'        1-й вариант объявления класса
'           Dim cMyClass As MyClass 'простое объявление класса (не инициализирован - Nothing)
'           ...
'           Set cMyClass = New MyClass  'инициализация класса - снижает производительность
'                                       'т.к. инициализация и выделение памяти происходит на стадии выполнения
'        2-й вариант (предпочтительный)
'        Dim cMyClass As New MyClass    'объявление класса и его инициализация (на стадии компиляции)
'
' ---------------------------------------------------------------------
' если тип переменной не указан, то по умолчанию принимается тип Variant, что не очень хорошо...
' (снижение производительности т.к. память выделяется по максимально возможному типу данных + определение реального типа)
'
'
