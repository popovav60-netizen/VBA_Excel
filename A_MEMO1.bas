' логические операции
'---------------------------
' And (и)
'   1 And 1 = 1
'   1 And 0 = 0
'   0 And 0 = 0
'
' Or (или)
'   1 Or 1 = 1
'   1 Or 0 = 1
'   0 Or 0 = 0
'
' Not (не)
'   Not 1 = 0
'   Not 0 = 1
'
' Xor (исключающее или)
'   1 Xor 1 = 0
'   1 Xor 0 = 1
'   0 Xor 0 = 0



' деление по модулю (остаток от деления)
'---------------------------
' 5 Mod 1 == 0          ' 5 - (1 * (5\1))   5\1 - целая часть от деления = 5
' 5 Mod 2 == 1          ' 5 - (2 * (5\2))   5\2 - целая часть от деления = 2
' 5 Mod 3 == 2          ' 5 - (3 * (5\3))   5\3 - целая часть от деления = 1
' 5 Mod 4 == 1          ' 5 - (4 * (5\4))
' 5 Mod 5 == 0          ' 5 - (5 * (5\5))
' ...
